// Prisma Schema для Scenario Builder
// База данных для хранения сценариев, выполнений, событий и метаданных

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Сценарий (Scenario Spec)
model Scenario {
  id          String   @id @default(uuid())
  name        String
  description String?
  spec        String   // JSON строка с ScenarioSpec
  version     String   @default("1.0.0")
  status      String   @default("draft") // draft, active, archived
  createdBy   String?
  /** Изоляция multi-tenant; заголовок API: X-Tenant-ID */
  tenantId    String   @default("default")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Связи
  executions  Execution[]
  templates   Template[]
  jobs        ScenarioJob[]
  triggers    QueueTrigger[]
  
  @@index([status])
  @@index([createdAt])
  @@index([tenantId])
  @@index([tenantId, status])
}

// Шаблон сценария (Template Library)
model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String   // saga, approval, async_callbacks, crm, antifraud, etc.
  spec        String   // JSON строка с ScenarioSpec
  scenarioId  String? // Если шаблон основан на существующем сценарии
  tags        String?  // JSON массив тегов
  version     String   @default("1.0.0")
  difficulty  String   @default("beginner") // beginner, intermediate, advanced
  isPublished Boolean  @default(false)
  mockConfig  String?  // JSON: mock tool configurations
  guide       String?  // markdown guide text
  /** Изоляция multi-tenant; заголовок API: X-Tenant-ID */
  tenantId    String   @default("default")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  scenario    Scenario? @relation(fields: [scenarioId], references: [id])
  
  @@index([category])
  @@index([name])
  @@index([tenantId])
  @@index([tenantId, category])
}

// Выполнение сценария (Execution)
model Execution {
  id            String   @id @default(uuid())
  scenarioId    String
  executionId   String   @unique // UUID выполнения
  userId        String?
  userRoles     String?  // JSON массив ролей
  status        String   @default("pending") // pending, running, completed, failed, compensated
  currentNodeId String?
  traceId       String?
  spanId        String?
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  failedAt      DateTime?
  errorMessage  String?
  errorCode     String?
  /** in_memory | temporal — единая модель для API и БД */
  runtimeKind          String   @default("in_memory")
  temporalRunId        String?
  temporalTaskQueue    String?
  temporalStatusName   String?
  temporalHistoryLength Int?
  /** Денормализация tenant для фильтров без join; совпадает с scenario.tenantId */
  tenantId             String   @default("default")
  
  // Связи
  scenario      Scenario        @relation(fields: [scenarioId], references: [id])
  events        ExecutionEvent[]
  nodeExecutions NodeExecution[]
  compensations Compensation[]
  
  @@index([scenarioId])
  @@index([executionId])
  @@index([status])
  @@index([startedAt])
  @@index([userId])
  @@index([tenantId])
  @@index([tenantId, startedAt])
}

// Событие выполнения (для восстановления состояния)
model ExecutionEvent {
  id            String   @id @default(uuid())
  executionId   String
  type          String   // trigger, node_started, node_completed, node_failed, compensation, etc.
  nodeId        String?
  data          String?  // JSON данные события
  metadata      String?  // JSON метаданные (eventId, correlationId, etc.)
  timestamp     DateTime @default(now())
  
  execution     Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  @@index([executionId])
  @@index([type])
  @@index([timestamp])
}

// Кэш успешного результата Temporal activity (идемпотентность при retry / рестарте воркера)
model TemporalToolActivityResult {
  id                  String   @id @default(uuid())
  dedupKey            String   @unique
  businessExecutionId String
  nodeId              String
  activityKind        String   @default("tool") // tool | agent
  toolId              String?
  outputsJson         String
  createdAt           DateTime @default(now())

  @@index([businessExecutionId])
  @@map("temporal_tool_activity_result")
}

// Выполнение узла workflow
model NodeExecution {
  id            String   @id @default(uuid())
  executionId   String
  nodeId        String
  state         String   @default("pending") // pending, running, completed, failed, compensated
  input         String?  // JSON входные данные
  output        String?  // JSON выходные данные
  error         String?  // JSON ошибка
  retryCount    Int      @default(0)
  startedAt     DateTime?
  completedAt   DateTime?
  duration      Int?     // миллисекунды
  
  execution     Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  @@unique([executionId, nodeId])
  @@index([executionId])
  @@index([nodeId])
  @@index([state])
}

// Компенсация (Saga pattern)
model Compensation {
  id            String   @id @default(uuid())
  executionId   String
  nodeId        String
  reason        String
  action        String   // JSON действие для компенсации
  status        String   @default("pending") // pending, completed, failed
  executedAt    DateTime?
  createdAt     DateTime @default(now())
  
  execution     Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  @@index([executionId])
  @@index([status])
}

// Инструмент (Tool)
model Tool {
  id              String   @id @default(uuid())
  toolId          String   @unique
  name            String
  description     String?
  inputSchema     String?  // JSON Schema для входов
  outputSchema    String?  // JSON Schema для выходов
  riskClass       String   @default("safe") // safe, moderate, high, requires_approval
  sla             String?  // JSON с SLA данными
  rateLimit       String?  // JSON с rate limit настройками
  authRequired    Boolean  @default(false)
  authScopes      String?  // JSON массив scope'ов
  idempotent      Boolean  @default(false)
  idempotencyKey  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([toolId])
  @@index([riskClass])
}

// Память агента (Agent Memory)
model AgentMemory {
  id            String   @id @default(uuid())
  memoryType    String   // short_term, long_term
  executionId   String?
  scenarioId   String?
  content       String   // Текст содержимого
  embedding     String?  // JSON массив чисел (векторное представление)
  metadata      String?  // JSON метаданные
  tags          String?  // JSON массив тегов
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([memoryType])
  @@index([executionId])
  @@index([scenarioId])
  @@index([createdAt])
}

// Конфигурация системы
model Configuration {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   // JSON значение
  category    String   @default("general") // general, llm, event_bus, observability, etc.
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
  
  @@index([category])
  @@index([key])
}

// Аудит (единый журнал событий безопасности и исполнения)
model AuditLog {
  id          String   @id @default(uuid())
  action      String   // scenario_started, scenario_completed, agent_execution, tool_call, guardrail_violation, eval_case, etc.
  actor       String?  // userId или service name
  resource    String?  // scenarioId, executionId, toolId
  outcome     String   @default("success") // success, failure, blocked, modified
  severity    String   @default("info")    // info, warning, error, critical
  message     String?
  details     String?  // JSON дополнительная нагрузка
  traceId     String?
  spanId      String?
  orgId       String?
  tenantId    String?
  timestamp   DateTime @default(now())

  @@index([action])
  @@index([actor])
  @@index([resource])
  @@index([outcome])
  @@index([timestamp])
  @@index([orgId, timestamp])
  @@index([tenantId, timestamp])
}

// Организация (multi-tenant root)
model Org {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")  // free, pro, business, enterprise
  status    String   @default("active") // active, suspended, deleted
  onboardingCompletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces Workspace[]
  members    OrgMember[]
  apiKeys    ApiKey[]

  @@index([slug])
  @@index([status])
}

model Workspace {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  slug        String
  tenantId    String   @unique  // maps 1:1 to existing tenantId
  environment String   @default("production") // production, staging, development
  settings    String?  // JSON
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id])

  @@unique([orgId, slug])
  @@index([orgId])
  @@index([tenantId])
}

model OrgMember {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  email     String
  role      String   @default("viewer") // owner, admin, builder, operator, viewer
  status    String   @default("active") // active, invited, suspended
  invitedBy String?
  joinedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id])

  @@unique([orgId, email])
  @@unique([orgId, userId])
  @@index([orgId])
  @@index([email])
}

// API-ключи для аутентификации запросов к API
model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyPrefix   String    // first 8 chars for display (e.g. "sb_live_a")
  keyHash     String    @unique // SHA-256 of full key
  tenantId    String    @default("default")
  createdBy   String    @default("system")
  roles       String    @default("[\"admin\"]") // JSON array
  scopes      String?   // JSON array; null = all scopes
  orgId       String?
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  org         Org?      @relation(fields: [orgId], references: [id])

  @@index([keyHash])
  @@index([tenantId])
}

// Метрики (для истории)
model Metric {
  id          String   @id @default(uuid())
  name        String
  value       Float
  labels      String?  // JSON объект с labels
  timestamp   DateTime @default(now())
  
  @@index([name])
  @@index([timestamp])
}

// Очередь сценариев (Scenario Queue)
model ScenarioQueue {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("active") // active, paused, stopped
  priority    Int      @default(0) // чем выше, тем приоритетнее
  maxConcurrency Int   @default(10) // максимальное количество одновременных выполнений
  retryConfig String?  // JSON с настройками повторов
  /** Изоляция multi-tenant; заголовок API: X-Tenant-ID */
  tenantId    String   @default("default")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Связи
  jobs        ScenarioJob[]
  triggers    QueueTrigger[]
  
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([tenantId])
  @@index([tenantId, status])
}

// Триггер очереди (связь между событиями и очередями)
model QueueTrigger {
  id          String   @id @default(uuid())
  queueId     String
  scenarioId  String?  // ID сценария для автоматического создания задания (опционально)
  eventType   String   // тип события для подписки
  topic       String   // Kafka topic
  filter      String?  // JSON фильтр для событий (опционально)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  queue       ScenarioQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  scenario    Scenario?     @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  
  @@index([queueId])
  @@index([scenarioId])
  @@index([eventType])
  @@index([topic])
  @@index([enabled])
}

// Задание в очереди (Scenario Job)
model ScenarioJob {
  id          String   @id @default(uuid())
  queueId     String
  scenarioId  String
  status      String   @default("pending") // pending, queued, running, completed, failed, cancelled
  priority    Int      @default(0)
  input       String?  // JSON входные данные для сценария
  output      String?  // JSON выходные данные
  error       String?  // JSON ошибка
  retryCount  Int      @default(0)
  maxRetries  Int      @default(3)
  executionId String?  // ID выполнения сценария (если создано)
  eventId     String?  // ID события, которое вызвало задание
  correlationId String? // для отслеживания цепочки событий
  createdAt   DateTime @default(now())
  queuedAt    DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  
  // Связи
  queue       ScenarioQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  scenario    Scenario      @relation(fields: [scenarioId], references: [id])
  
  @@index([queueId])
  @@index([scenarioId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([eventId])
  @@index([correlationId])
}

model WebhookEndpoint {
  id        String   @id @default(uuid())
  orgId     String
  url       String
  events    String   // JSON array of event types
  secret    String   // HMAC signing secret
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([active])
}

model UsageRecord {
  id          String   @id @default(uuid())
  orgId       String
  workspaceId String?
  tenantId    String   @default("default")
  period      String   // YYYY-MM format
  metric      String   // executions, tool_calls, llm_tokens, duration_ms, storage_bytes, api_calls
  value       Float    @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([orgId, tenantId, period, metric])
  @@index([orgId])
  @@index([tenantId])
  @@index([period])
}

model QuotaConfig {
  id        String   @id @default(uuid())
  orgId     String
  metric    String
  limitVal  Int      // renamed from 'limit' to avoid SQL keyword
  period    String   @default("monthly") // monthly, daily
  action    String   @default("warn") // warn, block, throttle
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, metric, period])
  @@index([orgId])
}
