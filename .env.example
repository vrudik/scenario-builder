# --- Web / server ---
PORT=3000

# --- Auth ---
# off (default) | optional | required
AUTH_MODE=off
# Single admin password for UI/API (leave empty to disable)
ADMIN_PASSWORD=

# --- Database (Prisma) ---
DATABASE_URL="file:./dev.db"
# execute-orchestrator: false — не поднимать Prisma-репозитории выполнений
ENABLE_DB=true

# --- Event Bus (Kafka) ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=scenario-builder
# В execute-orchestrator: не подключать Kafka, если ENABLE_EVENT_BUS=false
ENABLE_EVENT_BUS=true

# --- Durable execution (Temporal) ---
TEMPORAL_ADDRESS=localhost:7233
# execute-orchestrator / server: подключить TemporalClient и стартовать workflow
USE_TEMPORAL=false
# temporal-worker: поднять AgentRuntime для узлов type=agent
TEMPORAL_ENABLE_AGENT=0
# Orchestrator: false = только старт workflow; итог — syncTemporalExecutionResult(executionId)
TEMPORAL_AWAIT_RESULT=true
# temporal-worker: кэш успешных activity в БД (идемпотентность при retry). 0/false/off — отключить
# TEMPORAL_ACTIVITY_DEDUP=false
# Локальный smoke к реальному серверу: TEMPORAL_E2E=1 npx vitest run tests/temporal-server-smoke.test.ts
# TEMPORAL_E2E=1
# Vitest tests/temporal-scenario-workflow.test.ts: 1 — пропустить (нет dist или без test-server)
# SKIP_TEMPORAL_INTEGRATION=1

# Shadow strategy: параллельный дубль на canary (stub tools). 0/false — отключить
# SHADOW_CANARY_ENABLED=false

# --- Policy Engine (OPA) ---
# Сервер: opa run --server --addr :8181 policies/scenario/tool.rego policies/scenario/lane.rego
# Тесты: npm run test:opa  (бинарь OPA v0.69.x как в .github/workflows/ci.yml)
OPA_URL=

# Multi-tenant HTTP API (server.cjs): клиенты передают заголовок X-Tenant-ID; без него — тенант default
# In production, set to false to enforce OPA policy denials
OPA_FAIL_OPEN=true
OPA_TIMEOUT_MS=2500
# В OPA input (tool-gateway): allowedTools, forbiddenActions, requiresApproval, deploymentLane,
# canaryAllowedTools, canaryBlockedToolIds, scenarioPiiClassification, scenarioRiskClass, toolRiskClass,
# costLimits, tokenLimits, cost_guard_exceeded, tokensUsedSoFar, executionSpendUsd

# Оценка USD за один успешный вызов инструмента (если нет tool.estimatedCostUsdPerCall).
# Накапливается в оркестраторе / Temporal workflow / agent → OPA input.executionSpendUsd
EXECUTION_TOOL_COST_USD_DEFAULT=

# --- Agent runtime / LLM ---
# ollama (по умолчанию) | openai
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TEMPERATURE=
OLLAMA_MAX_TOKENS=
# Для LLM_PROVIDER=openai:
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=
OPENAI_MAX_TOKENS=

# --- Observability ---
OTEL_ENABLED=true
PROMETHEUS_PORT=9464
JAEGER_ENDPOINT=http://localhost:14268/api/traces
LOG_LEVEL=info

# --- Audit ---
AUDIT_RETENTION_DAYS=90

# --- Feature flags (legacy / другие entrypoints) ---
USE_KAFKA=false
USE_AGENT_RUNTIME=false

# --- Node / tests ---
NODE_ENV=development
