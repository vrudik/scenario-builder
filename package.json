{
  "name": "scenario-builder",
  "version": "0.1.1",
  "description": "Конструктор автономных сценариев и агентных процессов",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./sdk": "./dist/sdk/index.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/fix-dist-esm-imports.mjs",
    "example": "tsx examples/usage.ts",
    "example:agent": "tsx examples/agent-example.ts",
    "example:ollama": "tsx examples/agent-ollama-example.ts",
    "example:event-bus": "tsx examples/event-bus-example.ts",
    "test": "vitest",
    "test:opa": "node scripts/run-opa-test.mjs",
    "smoke:agent": "node scripts/smoke-agent-execute.mjs",
    "e2e:smoke": "node scripts/e2e-smoke.mjs",
    "e2e:smoke:auth": "node scripts/e2e-smoke-auth.mjs",
    "e2e:smoke:opa": "node scripts/e2e-smoke-opa.mjs",
    "sdk:types": "npx --yes openapi-typescript@7.6.1 docs/api/openapi.json -o src/sdk/openapi-types.ts",
    "sdk:v0": "npm run sdk:types",
    "bundle:opa": "node scripts/opa-bundle.mjs",
    "test:manual": "tsx test-manual.ts",
    "audit:find": "tsx src/web/audit-api.ts find",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "temporal:worker": "npm run build && node dist/runtime/temporal-worker.js",
    "web": "tsx src/web/server.ts",
    "web:start": "powershell -ExecutionPolicy Bypass -File start-web.ps1",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:deploy": "prisma migrate deploy",
    "db:migrate:fresh": "node scripts/fresh-sqlite-migrate.mjs",
    "db:reset": "prisma migrate reset",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t scenario-builder .",
    "staging:up": "docker compose -f docker-compose.staging.yml up -d --build",
    "staging:down": "docker compose -f docker-compose.staging.yml down"
  },
  "keywords": [
    "scenario",
    "agent",
    "orchestration",
    "workflow",
    "autonomous"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/exporter-jaeger": "^2.6.0",
    "@opentelemetry/exporter-prometheus": "^0.213.0",
    "@opentelemetry/instrumentation": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "^6.19.2",
    "@temporalio/client": "1.15.0",
    "@temporalio/worker": "1.15.0",
    "@temporalio/workflow": "1.15.0",
    "ajv": "^8.12.0",
    "kafkajs": "^2.2.4",
    "openai": "^4.20.0",
    "prisma": "^6.19.2",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@opentelemetry/instrumentation-fetch": "^0.213.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@temporalio/testing": "1.15.0",
    "@types/node": "^20.10.0",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/ui": "^1.0.4",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  }
}
